generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ХЭРЭГЛЭГЧ ───────────────────────────────────────────
  model User {
  id           String   @id @default(cuid())
  email        String   @unique
  nickname     String?  @unique
  phoneNumber  String?  @unique
  avatarUrl    String?
  passwordHash String                        // bcrypt, plain password хэзээ ч хадгалахгүй
  role         GlobalRole @default(ENGINEER)
  isActive     Boolean  @default(true)       // soft delete
  lastLoginAt  DateTime?

  projectMembers ProjectMember[]
  uploadedFiles  ProjectFile[]   @relation("Uploader")
  lockedFiles    ProjectFile[]   @relation("FileLock")
  fileVersions   FileVersion[]
  activities     FileActivity[]
  comments       Comment[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  createdTasks   Task[]          @relation("TaskCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GlobalRole {
  ADMIN
  MANAGER
  ENGINEER
}
model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// ─── ТӨСӨЛ ───────────────────────────────────────────────
model Project {
  id          String  @id @default(cuid())
  name        String
  description String?
  isArchived  Boolean @default(false)       // архивлах боломж

  members ProjectMember[]
  files   ProjectFile[]
  tasks   Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ТӨСЛИЙН ГИШҮҮНЧЛЭЛ ──────────────────────────────────
// Аль хэрэглэгч аль төсөлд ямар эрхтэй орохыг тодорхойлно
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

enum ProjectRole {
  OWNER     // бүх эрх, устгах
  EDITOR    // upload, lock, comment
  VIEWER    // зөвхөн харах, татах
}

// ─── ФАЙЛ ─────────────────────────────────────────────────
model ProjectFile {
  id        String  @id @default(cuid())
  projectId String
  name      String                          // "Survey_Plan_v3.dwg"
  mimeType  String                          // "application/dwg", "application/pdf"
  folder    String  @default("documents")
  viewerIds String[] @default([])
  editorIds String[] @default([])
  isLocked  Boolean @default(false)
  lockedById String?
  lockedAt   DateTime?

  uploaderId String
  uploader   User         @relation("Uploader", fields: [uploaderId], references: [id])
  lockedBy   User?        @relation("FileLock", fields: [lockedById], references: [id])
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions   FileVersion[]
  activities FileActivity[]
  comments   Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([uploaderId])
}

// ─── ФАЙЛЫН ХУВИЛБАР (Git-style) ──────────────────────────
model FileVersion {
  id            String @id @default(cuid())
  fileId        String
  uploadedById  String
  versionNumber Int                         // backend-ээс тооцно: MAX(versionNumber)+1
  fileUrl       String                      // MinIO object path
  fileData      Bytes?
  fileSize      BigInt                      // bytes
  checksum      String                      // sha256, integrity шалгах
  commitMsg     String?                     // "Тэнхлэгийн засвар хийв"

  file       ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploadedBy User        @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@unique([fileId, versionNumber])          // давхардал хориглоно
  @@index([fileId])
}

// ─── ФАЙЛЫН ХЯНАЛТ (Classroom-style) ──────────────────────
model FileActivity {
  id        String     @id @default(cuid())
  fileId    String
  userId    String
  action    ActionType
  ipAddress String?                         // аюулгүй байдлын аудит
  userAgent String?

  file ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([userId])
  @@index([createdAt])
}

enum ActionType {
  VIEW
  DOWNLOAD
  UPLOAD
  LOCK
  UNLOCK
  DELETE_VERSION
}

// ─── ДААЛГАВАР ────────────────────────────────────────────
model Task {
  id          String      @id @default(cuid())
  projectId   String
  assigneeId  String
  creatorId   String
  title       String
  description String?                       // Tiptap JSON
  status      TaskStatus  @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User    @relation("TaskCreator", fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── СЭТГЭГДЭЛ ────────────────────────────────────────────
model Comment {
  id       String  @id @default(cuid())
  fileId   String
  userId   String
  parentId String?                          // thread/reply дэмжинэ
  content  String
  isEdited Boolean @default(false)

  file     ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id])
  parent   Comment?    @relation("CommentThread", fields: [parentId], references: [id])
  replies  Comment[]   @relation("CommentThread")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fileId])
  @@index([parentId])
}
