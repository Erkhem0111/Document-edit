generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ХЭРЭГЛЭГЧ ───────────────────────────────────────────
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  nickname     String?    @unique
  phoneNumber  String?    @unique
  avatarUrl    String?
  passwordHash String
  role         GlobalRole @default(ENGINEER)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?

  projectMembers ProjectMember[]
  uploadedFiles  ProjectFile[]   @relation("Uploader")
  lockedFiles    ProjectFile[]   @relation("FileLock")
  fileVersions   FileVersion[]
  activities     FileActivity[]
  comments       Comment[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  createdTasks   Task[]          @relation("TaskCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GlobalRole {
  ADMIN
  MANAGER
  ENGINEER
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// ─── ТӨСӨЛ ───────────────────────────────────────────────
model Project {
  id          String  @id @default(cuid())
  name        String
  description String?
  isArchived  Boolean @default(false)

  members ProjectMember[]
  files   ProjectFile[]
  tasks   Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ТӨСЛИЙН ГИШҮҮНЧЛЭЛ ──────────────────────────────────
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

// ─── ФАЙЛ ─────────────────────────────────────────────────
model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  mimeType   String
  folder     String   @default("documents")
  viewerIds  String[] @default([])
  editorIds  String[] @default([])
  content    Json?
  isLocked   Boolean  @default(false)
  lockedById String?
  lockedAt   DateTime?

  uploaderId String
  uploader   User          @relation("Uploader", fields: [uploaderId], references: [id])
  lockedBy   User?         @relation("FileLock", fields: [lockedById], references: [id])
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions   FileVersion[]
  activities FileActivity[]
  comments   Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([uploaderId])
}

// ─── ФАЙЛЫН ХУВИЛБАР ──────────────────────────────────────
model FileVersion {
  id            String  @id @default(cuid())
  fileId        String
  uploadedById  String
  versionNumber Int
  fileUrl       String  // R2 object public URL
  fileSize      BigInt
  checksum      String
  commitMsg     String?

  file       ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploadedBy User        @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@unique([fileId, versionNumber])
  @@index([fileId])
}

// ─── ФАЙЛЫН ХЯНАЛТ ────────────────────────────────────────
model FileActivity {
  id        String     @id @default(cuid())
  fileId    String
  userId    String
  action    ActionType
  ipAddress String?
  userAgent String?

  file ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([userId])
  @@index([createdAt])
}

enum ActionType {
  VIEW
  DOWNLOAD
  UPLOAD
  LOCK
  UNLOCK
  DELETE_VERSION
}

// ─── ДААЛГАВАР ────────────────────────────────────────────
model Task {
  id          String       @id @default(cuid())
  projectId   String
  assigneeId  String
  creatorId   String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User    @relation("TaskCreator", fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── СЭТГЭГДЭЛ ────────────────────────────────────────────
model Comment {
  id       String  @id @default(cuid())
  fileId   String
  userId   String
  parentId String?
  content  String
  isEdited Boolean @default(false)

  file     ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id])
  parent   Comment?    @relation("CommentThread", fields: [parentId], references: [id])
  replies  Comment[]   @relation("CommentThread")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fileId])
  @@index([parentId])
}
